{
    "name": "florianv/swap-bundle",
    "type": "symfony-bundle",
    "description": "Integrates the Swap library with Symfony",
    "keywords": [
        "money",
        "currency",
        "conversion",
        "rate",
        "exchange",
        "symfony",
        "bundle"
    ],
    "homepage": "https://github.com/florianv/FlorianvSwapBundle",
    "license": "MIT",
    "authors": [
        {
            "name": "Florian Voutzinos",
            "email": "florian@voutzinos.com",
            "homepage": "http://florian.voutzinos.com"
        }
    ],
    "scripts": {
        "test": "vendor/bin/phpunit",
        "psalm": "vendor/bin/psalm --no-progress",
        "cs:fix": "vendor/bin/php-cs-fixer fix --no-interaction --ansi --quiet",
        "cs:check": "vendor/bin/php-cs-fixer fix --no-interaction --ansi --verbose --dry-run"
    },
    "require": {
        "php": "^8.2",
        "symfony/framework-bundle": "^6.4|^7.0|^8.0",
        "florianv/swap": "^4.0"
    },
    "require-dev": {
        "php-http/guzzle7-adapter": "^1.0",
        "php-http/message": "^1.7",
        "symfony/cache": "^6.4|^7.0|^8.0",
        "phpunit/phpunit": "^11.0|^12.0",
        "nyholm/psr7": "^1.1",
        "vimeo/psalm": "^6.0",
        "roave/backward-compatibility-check": "^8.9"
    },
    "suggest": {
        "symfony/cache": "For caching"
    },
    "autoload": {
        "psr-4": {
            "Florianv\\SwapBundle\\": ""
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Florianv\\SwapBundle\\Tests\\": "Tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "extra": {
        "branch-alias": {
            "dev-master": "5.0-dev"
        }
    }
}
